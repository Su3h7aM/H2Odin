#!/usr/bin/env bash
#MISE description="Format Odin sources with odinfmt (odinfmt.json)"
#MISE alias="fmt"
#MISE sources=["src/**/*.odin", "tests/**/*.odin", "vendored/libclang/**/*.odin", "examples/**/*.odin", "odinfmt.json", "scripts/format"]
#MISE outputs={auto=true}
#
# Format sources. Standalone: ./scripts/format
set -euo pipefail
# shellcheck source=scripts/_common.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_common.sh"

if ! command -v "$ODINFMT" >/dev/null 2>&1; then
	echo "error: odinfmt not found on PATH (set ODINFMT=...)" >&2
	exit 1
fi

"$ODINFMT" "$SRC_DIR" -config:odinfmt.json -w
if find "$TEST_DIR" -maxdepth 1 -name '*.odin' 2>/dev/null | grep -q .; then
	"$ODINFMT" "$TEST_DIR"/*.odin -config:odinfmt.json -w
fi
"$ODINFMT" vendored/libclang -config:odinfmt.json -w
"$ODINFMT" examples -config:odinfmt.json -w
