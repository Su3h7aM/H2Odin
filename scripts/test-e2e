#!/usr/bin/env bash
#MISE description="E2e tests (odin test tests/; needs build/h2odin)"
#MISE depends=["build"]
#MISE sources=["src/**/*.odin", "tests/**/*.odin", "tests/fixtures/**/*", "scripts/test-e2e", "scripts/_common.sh"]
#MISE outputs={auto=true}
#
# End-to-end tests against fixtures. Standalone: ./scripts/test-e2e
set -euo pipefail
# shellcheck source=scripts/_common.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_common.sh"

if ! find "$TEST_DIR" -maxdepth 1 -name '*.odin' 2>/dev/null | grep -q .; then
	echo "no e2e test package yet"
	exit 0
fi

ensure_built
run_odin test "$TEST_DIR" "${ODIN_FLAGS[@]}" "${COLLECTION_FLAGS[@]}" "${TEST_DEFINES[@]}"
